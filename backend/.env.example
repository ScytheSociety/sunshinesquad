# Puerto del servidor (dejar en 3000)
PORT=3000

# URL del frontend (GitHub Pages)
FRONTEND_URL=https://sunshinesquad.com

# Discord OAuth2
DISCORD_CLIENT_ID=TU_CLIENT_ID_AQUI
DISCORD_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
DISCORD_REDIRECT_URI=https://sunshinesquad.com/api/auth/callback

# JWT (genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_LARGO_Y_SEGURO

# Bases de datos
BOT_DB_PATH=/home/sunshinesquad/sunshinesquad/data/bot.sqlite3
WEB_DB_PATH=/home/sunshinesquad/sunshinesquad_web/web.db

# Web Push VAPID (genera con: npx web-push generate-vapid-keys)
VAPID_EMAIL=tu@email.com
VAPID_PUBLIC_KEY=GENERAR_CON_COMANDO_ABAJO
VAPID_PRIVATE_KEY=GENERAR_CON_COMANDO_ABAJO
